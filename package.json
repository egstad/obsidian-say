{
  "name": "obsidian-voice-notes-ai",
  "version": "1.1.0",
  "description": "Obsidian plugin: record audio, transcribe with Whisper, summarize & tag with Claude.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "deploy": "node esbuild.config.mjs production && node deploy.mjs"
  },
  "devDependencies": {
    "@types/node": "^16.11.6",
    "builtin-modules": "3.3.0",
    "esbuild": "0.17.3",
    "obsidian": "latest",
    "tslib": "2.4.0",
    "typescript": "4.7.4"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.51.0"
  }
}
